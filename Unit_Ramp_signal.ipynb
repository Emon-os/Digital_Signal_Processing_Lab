      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt"
      ],
      "metadata": {
        "id": "MpLRekP9d-wh"
      },
      "execution_count": 1,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# time axis\n",
        "t = np.linspace(-10, 10, 1000)\n",
        "\n",
        "# unit ramp signal\n",
        "r = np.where(t >= 0, t, 0)\n",
        "\n",
        "# plot\n",
        "plt.plot(t, r)\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Amplitude\")\n",
        "plt.title(\"Unit Ramp Signal\")\n",
        "plt.grid(True)\n",
        "plt.show()\n"
      ],
